# .env.example — template de variáveis de ambiente do aiops-lab
#
# Copie para .env e preencha os valores reais:
#   cp .env.example .env
#
# NUNCA commitar o .env — ele está no .gitignore.
# Este arquivo (.env.example) SIM é commitado: apenas placeholders.

# ─── Keep ────────────────────────────────────────────────────────────────────
# API key do backend Keep (padrão de lab: keepappkey).
# Em produção: gerar uma chave forte e armazenar como Secret no cluster.
KEEP_API_KEY=keepappkey

# ─── Microsoft Teams ─────────────────────────────────────────────────────────
# Webhook URL do canal que receberá as notificações de RCA.
# Como obter: canal do Teams → Conectores → Incoming Webhook → copiar URL.
TEAMS_WEBHOOK_URL=https://example.webhook.office.com/webhookb2/SUBSTITUIR

# ─── Grafana ─────────────────────────────────────────────────────────────────
# Senha do usuário admin do Grafana.
# Atenção: esta variável ainda NÃO é lida pelos scripts bash —
# ela é gerenciada pelo Helm via env/local.yaml (grafanaAdminPassword).
# Próxima etapa: converter env/local.yaml para env/local.yaml.gotmpl
# para suportar {{ env "GRAFANA_ADMIN_PASSWORD" }}.
GRAFANA_ADMIN_PASSWORD=admin
